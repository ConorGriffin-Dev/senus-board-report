# Copy to .env and fill in real values. Never commit .env.

# Database
DATABASE_URL=postgresql+asyncpg://senus:senus_dev_password@localhost:5432/senus_board_report

# Anthropic API (optional)
# This project uses fixture-based extraction and insight generation by
# default: AI outputs were generated manually via Claude.ai/ChatGPT and
# cached under extraction-pipeline/fixtures/, loaded into the database via
# a seed step. No key is required to run the app locally.
# Uncomment and set only if swapping the fixture-read call in
# extraction_service.py / insight_service.py for a live Anthropic API call.
# See "AI-assisted development workflow" in README.md for the full reasoning.
# ANTHROPIC_API_KEY=

# Backend
BACKEND_CORS_ORIGINS=http://localhost:5173
ENVIRONMENT=development

# Frontend (Vite exposes only VITE_-prefixed vars to the browser)
VITE_API_BASE_URL=http://localhost:8000